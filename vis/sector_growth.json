{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Distribution of one-year returns for ASX 200 companies by sector, excluding extreme outliers for readability.",
  "width": 760,
  "height": 470,
  "background": "transparent",
  "data": {
    "url": "data/asx200_companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum['1 Year'])",
      "as": "oneYearReturn"
    },
    {
      "filter": "datum.oneYearReturn >= -1 && datum.oneYearReturn <= 3"
    }
  ],
  "mark": {
    "type": "boxplot",
    "extent": 1.5,
    "size": 30
  },
  "encoding": {
    "x": {
      "field": "oneYearReturn",
      "type": "quantitative",
      "title": "One-year return",
      "scale": {
        "domain": [-1, 3]
      },
      "axis": {
        "format": ".0%",
        "grid": true,
        "gridColor": "#e6ded2",
        "tickCount": 7,
        "labelFontSize": 12,
        "titleFontSize": 13,
        "labelColor": "#243447",
        "titleColor": "#102033",
        "domainColor": "#b8c0c7",
        "tickColor": "#b8c0c7"
      }
    },
    "y": {
      "field": "Sector",
      "type": "nominal",
      "title": null,
      "sort": [
        "Financials",
        "Materials",
        "Industrials",
        "Consumer Discretionary",
        "Health Care",
        "Real Estate",
        "Energy",
        "Communication Services",
        "Consumer Staples",
        "Utilities",
        "Information Technology"
      ],
      "scale": {
        "paddingInner": 0.45,
        "paddingOuter": 0.55
      },
      "axis": {
        "labelFontSize": 12,
        "labelLimit": 220,
        "labelColor": "#243447",
        "domain": false,
        "ticks": false
      }
    },
    "color": {
      "field": "Sector",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": [
          "Financials",
          "Materials",
          "Industrials",
          "Consumer Discretionary",
          "Health Care",
          "Real Estate",
          "Energy",
          "Communication Services",
          "Consumer Staples",
          "Utilities",
          "Information Technology"
        ],
        "range": [
          "#547aa5",
          "#d58a3a",
          "#d95f4a",
          "#62a99b",
          "#4f9a64",
          "#d6b44c",
          "#9c6b9e",
          "#e88b9a",
          "#9a735c",
          "#9aa3a8",
          "#705780"
        ]
      }
    },
    "tooltip": [
      {
        "field": "Company",
        "type": "nominal",
        "title": "Company"
      },
      {
        "field": "Sector",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "oneYearReturn",
        "type": "quantitative",
        "title": "One-year return",
        "format": ".1%"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    }
  }
}