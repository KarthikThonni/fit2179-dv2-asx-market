{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Daily S&P/ASX 200 index level over one year with two major drops labelled.",
  "width": 760,
  "height": 420,
  "data": {
    "url": "data/asx_daily_returns.csv"
  },
  "transform": [
    {
      "calculate": "timeParse(datum.Date, '%d/%m/%Y') != null ? timeParse(datum.Date, '%d/%m/%Y') : timeParse(datum.Date, '%d/%m/%y')",
      "as": "date"
    },
    {
      "calculate": "toNumber(datum.ASX200)",
      "as": "asxValue"
    },
    {
      "filter": "isValid(datum.date) && isValid(datum.asxValue)"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {
          "color": "#2f8f68",
          "strokeWidth": 2.5
        },
        "color": {
          "x1": 1,
          "y1": 1,
          "x2": 1,
          "y2": 0,
          "gradient": "linear",
          "stops": [
            {
              "offset": 0,
              "color": "#fffdf8"
            },
            {
              "offset": 1,
              "color": "#2f8f68"
            }
          ]
        },
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Date",
          "axis": {
            "format": "%b %Y",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "grid": false
          }
        },
        "y": {
          "field": "asxValue",
          "type": "quantitative",
          "title": "S&P/ASX 200 index level",
          "scale": {
            "domain": [8000, 9600]
          },
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "grid": true,
            "gridColor": "#e6ded2"
          }
        },
        "y2": {
          "datum": 8000
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "asxValue",
            "type": "quantitative",
            "title": "S&P/ASX 200",
            "format": ",.2f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.5,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "strokeWidth": 1.6,
        "color": "#d95f4a"
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "eventValue",
          "type": "quantitative"
        },
        "y2": {
          "field": "labelY"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.5,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 100,
        "color": "#d95f4a",
        "stroke": "#fffdf8",
        "strokeWidth": 1.6
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "eventValue",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "eventDateParsed",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "eventValue",
            "type": "quantitative",
            "title": "S&P/ASX 200",
            "format": ",.2f"
          },
          {
            "field": "eventLabel",
            "type": "nominal",
            "title": "Reason"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.5,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#d95f4a",
        "dy": -4
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "labelY",
          "type": "quantitative"
        },
        "text": {
          "field": "eventLabel",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    }
  }
}