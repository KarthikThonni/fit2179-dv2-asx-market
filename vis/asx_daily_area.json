{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Daily S&P/ASX 200 index level over one year with two major drops labelled.",
  "width": 760,
  "height": 420,
  "data": {
    "url": "data/asx_daily_returns.csv"
  },
  "transform": [
    {
      "calculate": "timeParse(datum.Date, '%d/%m/%Y')",
      "as": "date"
    },
    {
      "calculate": "toNumber(datum.ASX200)",
      "as": "asxValue"
    },
    {
      "filter": "isValid(datum.date) && isValid(datum.asxValue)"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {
          "color": "#2e8b57",
          "strokeWidth": 2
        },
        "color": {
          "x1": 1,
          "y1": 1,
          "x2": 1,
          "y2": 0,
          "gradient": "linear",
          "stops": [
            {
              "offset": 0,
              "color": "white"
            },
            {
              "offset": 1,
              "color": "#2e8b57"
            }
          ]
        },
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Date",
          "axis": {
            "format": "%b %Y",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "grid": false
          }
        },
        "y": {
          "field": "asxValue",
          "type": "quantitative",
          "title": "S&P/ASX 200 index level",
          "scale": {
            "domain": [8000, 9600]
          },
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 13,
            "grid": true
          }
        },
        "y2": {
          "datum": 8000
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "asxValue",
            "type": "quantitative",
            "title": "S&P/ASX 200",
            "format": ",.2f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.50,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "strokeWidth": 1.5,
        "color": "#c0392b"
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "eventValue",
          "type": "quantitative"
        },
        "y2": {
          "field": "labelY"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.50,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 95,
        "color": "#c0392b",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "eventValue",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "eventDateParsed",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "eventValue",
            "type": "quantitative",
            "title": "S&P/ASX 200",
            "format": ",.2f"
          },
          {
            "field": "eventLabel",
            "type": "nominal",
            "title": "Reason"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "eventDate": "21/11/2025",
            "eventValue": 8416.50,
            "labelY": 9480,
            "eventLabel": "Tech and banks sell-off"
          },
          {
            "eventDate": "23/03/2026",
            "eventValue": 8365.92,
            "labelY": 9480,
            "eventLabel": "Geopolitical and oil price fears"
          }
        ]
      },
      "transform": [
        {
          "calculate": "timeParse(datum.eventDate, '%d/%m/%Y')",
          "as": "eventDateParsed"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#8e2c22",
        "dy": -4
      },
      "encoding": {
        "x": {
          "field": "eventDateParsed",
          "type": "temporal"
        },
        "y": {
          "field": "labelY",
          "type": "quantitative"
        },
        "text": {
          "field": "eventLabel",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}