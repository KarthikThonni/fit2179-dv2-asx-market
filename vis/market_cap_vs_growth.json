{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Scatter plot of ASX 200 company market capitalisation versus one-year return.",
  "width": 760,
  "height": 460,
  "data": {
    "url": "data/asx200_companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(replace(replace(datum['Mkt Cap'], '$', ''), 'B', ''))",
      "as": "marketCapB"
    },
    {
      "calculate": "toNumber(datum['1 Year'])",
      "as": "oneYearReturn"
    },
    {
      "filter": "isValid(datum.marketCapB) && isValid(datum.oneYearReturn)"
    },
    {
      "filter": "datum.oneYearReturn >= -1 && datum.oneYearReturn <= 3"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#c48a3a",
        "strokeDash": [4, 4],
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "datum": 0
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 85,
        "opacity": 0.82,
        "stroke": "#fffdf8",
        "strokeWidth": 0.9
      },
      "encoding": {
        "x": {
          "field": "marketCapB",
          "type": "quantitative",
          "title": "Market cap ($B, log scale)",
          "scale": {
            "type": "log"
          },
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "grid": false
          }
        },
        "y": {
          "field": "oneYearReturn",
          "type": "quantitative",
          "title": "One-year return",
          "scale": {
            "domain": [-1, 3]
          },
          "axis": {
            "format": ".0%",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "grid": false
          }
        },
        "color": {
          "field": "Sector",
          "type": "nominal",
          "title": "Sector",
          "scale": {
            "domain": [
              "Financials",
              "Materials",
              "Industrials",
              "Consumer Discretionary",
              "Health Care",
              "Real Estate",
              "Energy",
              "Communication Services",
              "Consumer Staples",
              "Utilities",
              "Information Technology"
            ],
            "range": [
              "#547aa5",
              "#d58a3a",
              "#d95f4a",
              "#62a99b",
              "#4f9a64",
              "#d6b44c",
              "#9c6b9e",
              "#e88b9a",
              "#9a735c",
              "#9aa3a8",
              "#705780"
            ]
          },
          "legend": {
            "title": "Sector",
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12,
            "symbolSize": 140,
            "rowPadding": 6,
            "labelColor": "#243447",
            "titleColor": "#102033"
          }
        },
        "tooltip": [
          {
            "field": "Company",
            "type": "nominal",
            "title": "Company"
          },
          {
            "field": "Sector",
            "type": "nominal",
            "title": "Sector"
          },
          {
            "field": "marketCapB",
            "type": "quantitative",
            "title": "Market cap ($B)",
            "format": ".1f"
          },
          {
            "field": "oneYearReturn",
            "type": "quantitative",
            "title": "One-year return",
            "format": ".1%"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domain": true,
      "ticks": true,
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#243447",
      "titleColor": "#102033"
    }
  }
}