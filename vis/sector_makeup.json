{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "ASX 200 sector makeup by total market capitalisation.",
  "width": 343,
  "height": 277,
  "background": "transparent",
  "data": {
    "url": "data/asx200_companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(replace(replace(datum['Mkt Cap'], '$', ''), 'B', ''))",
      "as": "marketCapB"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "marketCapB",
          "as": "totalMarketCapB"
        }
      ],
      "groupby": ["Sector"]
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "totalMarketCapB",
          "as": "overallMarketCapB"
        }
      ]
    },
    {
      "calculate": "datum.totalMarketCapB / datum.overallMarketCapB",
      "as": "sectorShare"
    },
    {
      "calculate": "format(datum.sectorShare, '.1%')",
      "as": "sectorShareLabel"
    },
    {
      "calculate": "'$' + format(datum.totalMarketCapB, ',.1f') + 'B'",
      "as": "sectorMarketCapLabel"
    },
    {
      "calculate": "datum.Sector + ' (' + datum.sectorMarketCapLabel + ')'",
      "as": "sectorLegendLabel"
    },
    {
      "calculate": "'$' + format(datum.overallMarketCapB, ',.1f') + 'B'",
      "as": "overallLabel"
    },
    {
      "window": [
        {
          "op": "row_number",
          "as": "rowNum"
        }
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 53,
        "outerRadius": 119,
        "stroke": "#fffdf8",
        "strokeWidth": 1.4
      },
      "encoding": {
        "theta": {
          "field": "totalMarketCapB",
          "type": "quantitative"
        },
        "order": {
          "field": "totalMarketCapB",
          "type": "quantitative",
          "sort": "descending"
        },
        "color": {
          "field": "sectorLegendLabel",
          "type": "nominal",
          "title": "Sector market cap",
          "sort": {
            "field": "totalMarketCapB",
            "order": "descending"
          },
          "scale": {
            "domain": [
              "Financials ($933.8B)",
              "Materials ($746.6B)",
              "Industrials ($219.0B)",
              "Consumer Discretionary ($171.6B)",
              "Health Care ($170.5B)",
              "Real Estate ($157.2B)",
              "Energy ($129.8B)",
              "Communication Services ($118.2B)",
              "Consumer Staples ($89.1B)",
              "Utilities ($61.2B)",
              "Information Technology ($61.1B)"
            ],
           "range": [
            "#547aa5",
            "#d58a3a",
            "#d95f4a",
            "#62a99b",
            "#6F7F8F",
            "#d6b44c",
            "#9c6b9e",
            "#e88b9a",
            "#9a735c",
            "#9aa3a8",
            "#705780"
          ]
          },
          "legend": {
            "offset": 25,
            "labelFontSize": 13,
            "titleFontSize": 14,
            "symbolSize": 180,
            "rowPadding": 10,
            "labelLimit": 380,
            "labelColor": "#243447",
            "titleColor": "#102033"
          }
        },
        "tooltip": [
          {
            "field": "Sector",
            "type": "nominal",
            "title": "Sector"
          },
          {
            "field": "totalMarketCapB",
            "type": "quantitative",
            "title": "Total market cap ($B)",
            "format": ".1f"
          },
          {
            "field": "sectorShare",
            "type": "quantitative",
            "title": "Share of ASX 200 market cap",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.rowNum == 1"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 14,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "middle",
        "color": "#243447"
      },
      "encoding": {
        "x": {
          "value": 172
        },
        "y": {
          "value": 128
        },
        "text": {
          "value": "Total Mkt Cap"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.rowNum == 1"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 16,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "middle",
        "color": "#102033"
      },
      "encoding": {
        "x": {
          "value": 172
        },
        "y": {
          "value": 151
        },
        "text": {
          "field": "overallLabel",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#243447",
      "titleColor": "#102033"
    }
  }
}