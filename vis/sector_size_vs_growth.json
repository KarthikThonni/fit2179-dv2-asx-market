{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bubble plot comparing sector market cap and sector growth in the ASX 200.",
  "width": 760,
  "height": 460,
  "data": {
    "url": "data/asx200_companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(replace(replace(datum['Mkt Cap'], '$', ''), 'B', ''))",
      "as": "marketCapB"
    },
    {
      "calculate": "toNumber(datum['1 Year'])",
      "as": "oneYearReturn"
    },
    {
      "filter": "isValid(datum.marketCapB) && isValid(datum.oneYearReturn)"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "marketCapB",
          "as": "totalSectorMarketCapB"
        },
        {
          "op": "median",
          "field": "oneYearReturn",
          "as": "medianSectorReturn"
        },
        {
          "op": "count",
          "field": "Company",
          "as": "companyCount"
        }
      ],
      "groupby": ["Sector"]
    }
  ],
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.85,
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "totalSectorMarketCapB",
      "type": "quantitative",
      "title": "Total sector market cap ($B)",
      "axis": {
        "labelFontSize": 12,
        "titleFontSize": 13,
        "grid": true
      }
    },
    "y": {
      "field": "medianSectorReturn",
      "type": "quantitative",
      "title": "Median one-year return",
      "axis": {
        "format": ".0%",
        "labelFontSize": 12,
        "titleFontSize": 13,
        "grid": true
      }
    },
    "size": {
      "field": "companyCount",
      "type": "quantitative",
      "title": "Number of companies",
      "scale": {
        "range": [300, 3000]
      },
      "legend": {
        "title": "Number of companies",
        "orient": "top",
        "direction": "horizontal",
        "labelFontSize": 11,
        "titleFontSize": 12,
        "symbolFillColor": "#555555",
        "symbolStrokeColor": "#555555",
        "symbolOpacity": 0.85,
        "columns": 6,
        "offset": 10,
        "padding": 12
      }
    },
    "color": {
      "field": "Sector",
      "type": "nominal",
      "title": "Sector",
      "scale": {
        "domain": [
          "Financials",
          "Materials",
          "Industrials",
          "Consumer Discretionary",
          "Health Care",
          "Real Estate",
          "Energy",
          "Communication Services",
          "Consumer Staples",
          "Utilities",
          "Information Technology"
        ],
        "range": [
          "#4e79a7",
          "#f28e2b",
          "#e15759",
          "#76b7b2",
          "#59a14f",
          "#edc948",
          "#b07aa1",
          "#ff9da7",
          "#9c755f",
          "#bab0ab",
          "#6f4e7c"
        ]
      },
      "legend": {
        "title": "Sector",
        "orient": "right",
        "labelFontSize": 11,
        "titleFontSize": 12,
        "symbolSize": 130,
        "rowPadding": 8,
        "offset": 35
      }
    },
    "tooltip": [
      {
        "field": "Sector",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "totalSectorMarketCapB",
        "type": "quantitative",
        "title": "Total market cap ($B)",
        "format": ".1f"
      },
      {
        "field": "medianSectorReturn",
        "type": "quantitative",
        "title": "Median one-year return",
        "format": ".1%"
      },
      {
        "field": "companyCount",
        "type": "quantitative",
        "title": "Number of companies"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}