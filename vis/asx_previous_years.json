{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "ASX 200 yearly capital returns from 2015 to 2025 with average return line.",
  "width": 760,
  "height": 380,
  "data": {
    "url": "data/asx_yearly_returns.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum['Capital Return of ASX 200 (%)']) / 100",
      "as": "returnRate"
    },
    {
      "calculate": "format(datum.returnRate, '.1%')",
      "as": "returnLabel"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "domain": false,
            "ticks": false,
            "labelAngle": 0,
            "labelPadding": 4,
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033"
          }
        },
        "y": {
          "field": "returnRate",
          "type": "quantitative",
          "title": "Capital return",
          "scale": {
            "domain": [-0.1, 0.25]
          },
          "axis": {
            "format": ".0%",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "gridColor": {
              "condition": {
                "test": "datum.value === 0",
                "value": "#102033"
              },
              "value": "#e6ded2"
            }
          }
        },
        "color": {
          "field": "returnRate",
          "type": "quantitative",
          "scale": {
            "domain": [-0.05, 0, 0.25],
            "range": ["#d95f4a", "#e6ded2", "#2f8f68"]
          },
          "legend": {
            "title": "Return",
            "orient": "top",
            "offset": 10,
            "format": ".0%",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "returnRate",
            "type": "quantitative",
            "title": "Capital return",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeDash": [6, 4],
        "strokeWidth": 2,
        "color": "#102033"
      },
      "encoding": {
        "y": {
          "aggregate": "average",
          "field": "returnRate",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 8,
        "dy": -6,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "x": {
          "datum": "2025"
        },
        "y": {
          "aggregate": "average",
          "field": "returnRate",
          "type": "quantitative"
        },
        "text": {
          "value": "Average"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.returnRate >= 0"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -5,
        "fontSize": 11,
        "fontWeight": "600",
        "color": "#102033"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "returnRate",
          "type": "quantitative"
        },
        "text": {
          "field": "returnLabel"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.returnRate < 0"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 5,
        "fontSize": 11,
        "fontWeight": "600",
        "color": "#102033"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "returnRate",
          "type": "quantitative"
        },
        "text": {
          "field": "returnLabel"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#243447",
      "titleColor": "#102033"
    }
  }
}