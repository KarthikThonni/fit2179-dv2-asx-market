{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "ASX 200 market concentration by company market capitalisation.",
  "width": 502,
  "height": 277,
  "background": "transparent",
  "data": {
    "url": "data/asx200_companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(replace(replace(datum['Mkt Cap'], '$', ''), 'B', ''))",
      "as": "marketCapB"
    },
    {
      "filter": "isValid(datum.marketCapB)"
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "companyRank"
        },
        {
          "op": "sum",
          "field": "marketCapB",
          "as": "cumulativeMarketCapB"
        }
      ],
      "sort": [
        {
          "field": "marketCapB",
          "order": "descending"
        }
      ]
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "marketCapB",
          "as": "totalMarketCapB"
        }
      ]
    },
    {
      "calculate": "datum.cumulativeMarketCapB / datum.totalMarketCapB",
      "as": "cumulativeShare"
    },
    {
      "filter": "datum.companyRank <= 50"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "opacity": 0.88,
        "color": "#547aa5",
        "cornerRadiusEnd": 2
      },
      "encoding": {
        "x": {
          "field": "companyRank",
          "type": "ordinal",
          "title": "Company rank by market cap",
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 10,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "domain": false,
            "ticks": false
          }
        },
        "y": {
          "field": "marketCapB",
          "type": "quantitative",
          "title": "Market cap ($B)",
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "grid": true,
            "gridColor": "#e6ded2"
          }
        },
        "tooltip": [
          {
            "field": "companyRank",
            "type": "ordinal",
            "title": "Rank"
          },
          {
            "field": "Company",
            "type": "nominal",
            "title": "Company"
          },
          {
            "field": "Sector",
            "type": "nominal",
            "title": "Sector"
          },
          {
            "field": "marketCapB",
            "type": "quantitative",
            "title": "Market cap ($B)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#d95f4a",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 30,
          "color": "#d95f4a",
          "stroke": "#fffdf8",
          "strokeWidth": 1
        }
      },
      "encoding": {
        "x": {
          "field": "companyRank",
          "type": "ordinal"
        },
        "y": {
          "field": "cumulativeShare",
          "type": "quantitative",
          "title": "Cumulative share",
          "scale": {
            "domain": [0, 1]
          },
          "axis": {
            "orient": "right",
            "format": ".0%",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "labelColor": "#243447",
            "titleColor": "#102033",
            "labelPadding": 8,
            "titlePadding": 18,
            "grid": false
          }
        },
        "tooltip": [
          {
            "field": "companyRank",
            "type": "ordinal",
            "title": "Rank"
          },
          {
            "field": "Company",
            "type": "nominal",
            "title": "Company"
          },
          {
            "field": "cumulativeShare",
            "type": "quantitative",
            "title": "Cumulative share",
            "format": ".1%"
          }
        ]
      }
    }
  ],
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    }
  }
}