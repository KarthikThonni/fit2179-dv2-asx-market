{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "World map showing one-year stock market growth by country.",
  "width": 680,
  "height": 360,
  "projection": {
    "type": "naturalEarth1"
  },
  "layer": [
    {
      "data": {
        "graticule": true
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#eeeeee",
        "strokeWidth": 0.4
      }
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "data/world_index_returns.csv"
            },
            "key": "id",
            "fields": ["Asset", "1Y"]
          }
        },
        {
          "filter": "datum['1Y'] == null || datum['1Y'] === ''"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#b0b7c3",
        "stroke": "#ffffff",
        "strokeWidth": 0.5,
        "opacity": 0.85
      },
      "encoding": {
        "tooltip": [
          {
            "value": "No index data available",
            "title": "Country"
          }
        ]
      }
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "data/world_index_returns.csv"
            },
            "key": "id",
            "fields": ["Asset", "1Y"]
          }
        },
        {
          "filter": "datum['1Y'] != null && datum['1Y'] !== ''"
        },
        {
          "calculate": "toNumber(datum['1Y']) / 100",
          "as": "oneYearReturn"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.7
      },
      "encoding": {
        "color": {
          "field": "oneYearReturn",
          "type": "quantitative",
          "title": "One-year return",
          "scale": {
            "domain": [-0.2, 0, 0.2, 0.8],
            "range": ["#d6604d", "#ffffff", "#bfe7cc", "#2e8b57"],
            "clamp": true
          },
          "legend": {
            "title": "One-year return",
            "format": ".0%"
          }
        },
        "tooltip": [
          {
            "field": "Asset",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "oneYearReturn",
            "type": "quantitative",
            "title": "One-year return",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "data": {
        "values": [{}]
      },
      "mark": {
        "type": "rect",
        "fill": "#b0b7c3",
        "stroke": "#888888"
      },
      "encoding": {
        "x": {
          "value": 555
        },
        "x2": {
          "value": 570
        },
        "y": {
          "value": 300
        },
        "y2": {
          "value": 315
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "label": "No index to measure"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 18,
        "fontSize": 11,
        "color": "#333333"
      },
      "encoding": {
        "x": {
          "value": 570
        },
        "y": {
          "value": 307
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}