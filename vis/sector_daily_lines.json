{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Monthly percentage change of ASX sectors and the ASX200 benchmark over time.",
  "width": 760,
  "height": 430,
  "background": "transparent",
  "data": {
    "url": "data/asx_daily_returns.csv"
  },
  "transform": [
    {
      "calculate": "timeParse(datum.Date, '%d/%m/%Y') != null ? timeParse(datum.Date, '%d/%m/%Y') : timeParse(datum.Date, '%d/%m/%y')",
      "as": "date"
    },
    {
      "fold": [
        "ASX200",
        "Financials (XFJ)",
        "Materials (XMJ)",
        "Consumer Discretionary (XDJ)",
        "Health Care (XHJ)",
        "Real Estate (XRE)",
        "Energy (XEJ)",
        "Industrials (XNJ)",
        "Communication Services (XTJ)",
        "Utilities (XUJ)",
        "Information Technology (XIJ)",
        "Consumer Staples (XSJ)"
      ],
      "as": ["Sector", "SectorIndex"]
    },
    {
      "calculate": "toNumber(datum.SectorIndex)",
      "as": "sectorValue"
    },
    {
      "filter": "datum.date != null && isFinite(datum.sectorValue)"
    },
    {
      "calculate": "timeFormat(datum.date, '%Y-%m')",
      "as": "monthKey"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "date",
          "as": "lastDateOfMonth"
        }
      ],
      "groupby": ["Sector", "monthKey"]
    },
    {
      "filter": "datum.date == datum.lastDateOfMonth"
    },
    {
      "window": [
        {
          "op": "first_value",
          "field": "sectorValue",
          "as": "startValue"
        }
      ],
      "sort": [
        {
          "field": "date",
          "order": "ascending"
        }
      ],
      "groupby": ["Sector"]
    },
    {
      "calculate": "(datum.sectorValue - datum.startValue) / datum.startValue",
      "as": "percentChange"
    }
  ],
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Month",
      "axis": {
        "format": "%b %Y",
        "labelFontSize": 12,
        "titleFontSize": 13,
        "labelColor": "#243447",
        "titleColor": "#102033",
        "grid": false,
        "domainColor": "#b8c0c7",
        "tickColor": "#b8c0c7"
      }
    },
    "y": {
      "field": "percentChange",
      "type": "quantitative",
      "title": "Percentage change from start",
      "axis": {
        "format": ".0%",
        "labelFontSize": 12,
        "titleFontSize": 13,
        "labelColor": "#243447",
        "titleColor": "#102033",
        "grid": true,
        "gridColor": "#e6ded2",
        "domainColor": "#b8c0c7",
        "tickColor": "#b8c0c7"
      }
    },
    "tooltip": [
      {
        "field": "date",
        "type": "temporal",
        "title": "Month",
        "format": "%b %Y"
      },
      {
        "field": "Sector",
        "type": "nominal",
        "title": "Series"
      },
      {
        "field": "percentChange",
        "type": "quantitative",
        "title": "Change from start",
        "format": ".1%"
      },
      {
        "field": "sectorValue",
        "type": "quantitative",
        "title": "Index level",
        "format": ".2f"
      }
    ]
  },
  "layer": [
    {
      "transform": [
        {
          "filter": "datum.Sector != 'ASX200'"
        }
      ],
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 45,
          "stroke": "#fffdf8",
          "strokeWidth": 0.8
        },
        "strokeWidth": 2,
        "opacity": 0.82
      },
      "encoding": {
        "color": {
          "field": "Sector",
          "type": "nominal",
          "title": "Series",
          "scale": {
            "domain": [
              "ASX200",
              "Financials (XFJ)",
              "Materials (XMJ)",
              "Industrials (XNJ)",
              "Consumer Discretionary (XDJ)",
              "Health Care (XHJ)",
              "Real Estate (XRE)",
              "Energy (XEJ)",
              "Communication Services (XTJ)",
              "Consumer Staples (XSJ)",
              "Utilities (XUJ)",
              "Information Technology (XIJ)"
            ],
            "range": [
              "#102033",
              "#547aa5",
              "#d58a3a",
              "#d95f4a",
              "#62a99b",
              "#4f9a64",
              "#d6b44c",
              "#9c6b9e",
              "#e88b9a",
              "#9a735c",
              "#9aa3a8",
              "#705780"
            ]
          },
          "legend": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "symbolSize": 120,
            "rowPadding": 5,
            "labelColor": "#243447",
            "titleColor": "#102033"
          }
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Sector == 'ASX200'"
        }
      ],
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 60,
          "color": "#102033",
          "stroke": "#fffdf8",
          "strokeWidth": 1
        },
        "strokeWidth": 4,
        "strokeDash": [6, 4],
        "color": "#102033"
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#b8c0c7",
      "tickColor": "#b8c0c7"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#243447",
      "titleColor": "#102033"
    }
  }
}